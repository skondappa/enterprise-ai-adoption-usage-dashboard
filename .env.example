# =============================================================================
# Enterprise AI Adoption Dashboard — environment template
#
# Copy to `.env` and fill in. Anything left blank disables that adapter.
# Multiple adapters can be enabled at once.
# =============================================================================

# Comma-separated. Default: mock (demo).
# Examples:
#   ENABLED_ADAPTERS=mock
#   ENABLED_ADAPTERS=ms-copilot,gh-copilot
#   ENABLED_ADAPTERS=ms-copilot,gh-copilot,amazon-q,claude-code
ENABLED_ADAPTERS=mock

# -----------------------------------------------------------------------------
# Microsoft Copilot — see docs/data-sources/microsoft-copilot.md
# -----------------------------------------------------------------------------
# MS_TENANT_ID=
# MS_CLIENT_ID=
# MS_CLIENT_SECRET=
# MS_GRAPH_SCOPE=https://graph.microsoft.com/.default

# -----------------------------------------------------------------------------
# GitHub Copilot — see docs/data-sources/github-copilot.md
# -----------------------------------------------------------------------------
# GITHUB_TOKEN=
# GITHUB_ENTERPRISE=                    # OR GITHUB_ORG, not both
# GITHUB_ORG=

# -----------------------------------------------------------------------------
# Amazon Q Developer — see docs/data-sources/amazon-q.md
# -----------------------------------------------------------------------------
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_Q_NAMESPACE=AWS/CodeWhisperer

# -----------------------------------------------------------------------------
# Claude Code (Anthropic) — see docs/data-sources/claude-code.md
# -----------------------------------------------------------------------------
# ANTHROPIC_ADMIN_KEY=
# ANTHROPIC_ORG_ID=

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=5000
FLASK_DEBUG=1
